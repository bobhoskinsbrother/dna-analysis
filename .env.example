DNA_DB_PATH=dna_analysis.duckdb
DNA_BATCH_SIZE=10000
# For Claude: model starts with "claude", uses Anthropic SDK automatically
DNA_LLM_MODEL=claude-sonnet-4-20250514
DNA_LLM_API_KEY=sk-ant-...
# For OpenAI: any non-claude model name uses OpenAI SDK
# DNA_LLM_MODEL=gpt-4o-mini
# DNA_LLM_API_KEY=sk-...
# DNA_LLM_API_BASE=                  # optional, for Ollama etc.
